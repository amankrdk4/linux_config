;; ===========================================================
;; POLYBAR FINAL BEAUTIFIED CONFIG
;; ===========================================================

[colors]
background = #1e222a
background-alt = #373b41
foreground = #C5C8C6
primary = #61afef
secondary = #8ABEB7
alert = #A54242
disabled = #707880
success = #98c379
warning = #e5c07b

[bar/mybar]
width = 98%
height = 34
offset-x = 1%
offset-y = 8pt
radius = 12
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3pt
border-size = 4pt
border-color = #00000000

padding-left = 1
padding-right = 2
module-margin = 1

separator = "|"
separator-foreground = ${colors.disabled}

; Font configuration for FiraCode Nerd Font
font-0 = "FiraCode Nerd Font:style=Bold:size=14;4"
font-1 = "FiraCode Nerd Font:size=16;4"
font-2 = "FiraCode Nerd Font:size=16;4"

modules-left = xworkspaces xwindow
modules-center = date
modules-right = mic-toggle backlight pulseaudio filesystem memory cpu wlan battery 

cursor-click = pointer
enable-ipc = true

;; ===========================================================
;; LEFT MODULES
;; ===========================================================

[module/xworkspaces]
type = internal/xworkspaces
label-active = %name%
label-active-background = ${colors.background-alt}
label-active-underline= ${colors.primary}
label-active-padding = 2

label-occupied = %name%
label-occupied-padding = 2

label-urgent = %name%
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

label-empty = %name%
label-empty-foreground = ${colors.disabled}
label-empty-padding = 2

[module/xwindow]
type = internal/xwindow
label = %title:0:30:...%
label-padding = 1

;; ===========================================================
;; CENTER MODULES
;; ===========================================================

[module/date]
type = internal/date
interval = 1

; Normal format: Just the time
date = "ď€— %I:%M %p"
; Expanded format: Clicking toggles to this (Date + Seconds)
date-alt = "ď€— %Y-%m-%d %I:%M:%S %p"

label = %date%
label-foreground = ${colors.primary}

;; ===========================================================
;; RIGHT MODULES
;; ===========================================================

[module/mic-toggle]
type = custom/script
exec = pactl get-source-mute $(pactl list sources | grep 'Name: ' | grep -v monitor | awk '{print $2}' | head -n 1) | grep -q "yes" && echo "ď„° OFF" || echo "ď„° ON"
interval = 1
click-left = ~/.config/polybar/scripts/toggle-mic.sh
label-foreground = ${colors.secondary}

[module/backlight]
type = internal/backlight
card = intel_backlight
format = <label>
label = "ď†… %percentage%%"
label-foreground = ${colors.warning}

[module/pulseaudio]
type = internal/pulseaudio
format-volume = <label-volume>
label-volume = "ď€¨ %percentage%%"
label-volume-foreground = ${colors.primary}
label-muted = "ď€¦ Muted"
label-muted-foreground = ${colors.disabled}

[module/filesystem]
type = internal/fs
mount-0 = /
interval = 30
label-mounted = "ď‚  %percentage_used%%"
label-mounted-foreground = ${colors.success}

[module/memory]
type = internal/memory
interval = 3
; Swapped for a more compatible memory icon
label = "ó°Ť› %percentage_used%%"
label-foreground = ${colors.secondary}

[module/cpu]
type = internal/cpu
interval = 3
label = "ď‹› %percentage%%"
label-foreground = ${colors.primary}

[module/wlan]
type = internal/network
interface-type = wireless
label-connected = "ď‡« "
label-connected-foreground = ${colors.success}
label-disconnected = "ó°–Ş"
label-disconnected-foreground = ${colors.alert}

[module/battery]
type = internal/battery
full-at = 99
battery = BAT1
adapter = ACAD
poll-interval = 5
format-charging = <label-charging>
format-discharging = <label-discharging>
label-charging = "ď‡¦ %percentage%%"
label-discharging = "ď‰‚ %percentage%%"
label-full = "ď‰€ %percentage%%"
label-charging-foreground = ${colors.warning}
label-discharging-foreground = ${colors.success}

[settings]
screenchange-reload = true
pseudo-transparency = true
